{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug OpenSpace (macOS)",
      "type": "lldb",
      "request": "launch",
      "program": "${workspaceFolder}/.vscode/DerivedData/Build/Products/Debug/OpenSpace.app/Contents/MacOS/OpenSpace",
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "Build OpenSpace (macOS Debug)",
      "sourceLanguages": [
        "swift"
      ]
    },
    {
      "name": "Run OpenSpace (iOS Simulator)",
      "type": "node-terminal",
      "request": "launch",
      "command": "bash \"${workspaceFolder}/.vscode/run-ios-simulator.sh\""
    }
  ]
}
