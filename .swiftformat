# LinkedIn Swift Style Guide mapped to SwiftFormat rules
# Source: https://github.com/linkedin/swift-style-guide
# Note: the LinkedIn repository does not provide a .swiftformat file; this config
# maps the guide's formatting rules to SwiftFormat options where possible.

# Exclude checkout/build directories for common package managers.
--exclude Carthage,Pods,.build

# Project / parser compatibility.
--swift-version 6.0

# 1.1 Use 4 spaces for tabs.
# 1.9 Follow Xcode's recommended indentation style.
--indent 4
--tab-width 4
--smart-tabs enabled
--xcode-indentation enabled
--indent-case false
--indent-strings true
--ifdef indent

# 1.2 Hard maximum of 160 characters per line.
--max-width 160

# 1.3 Newline at end of every file.
# 1.4 No trailing whitespace.
--linebreaks lf
--trim-whitespace always

# 1.5 Same-line braces for single-line statements; multiline statements wrap
# their closing paren / brace in SwiftFormat's balanced style.
# 3.1.13 Keep else/catch on the same line as the previous block.
--allman false
--else-position same-line
--guard-else next-line
--closing-paren balanced
--call-site-paren balanced

# 1.6-1.8 Spacing around colons, commas, operators, braces, parens, and generics.
--ranges preserve
--operator-func spaced
--type-delimiter space-after

# 1.10-1.11 Multiline calls, declarations, collections, closures.
--wrap-arguments before-first
--wrap-parameters before-first
--wrap-collections before-first
--wrap-conditions before-first
--wrap-return-type never
--wrap-effects preserve
--wrap-type-aliases before-first
--allow-partial-wrapping false
--trailing-commas collections-only

# 3.1.3 Prefer inferred types where possible.
# 3.1.8 Avoid parentheses around control-flow predicates.
# 3.1.11 Prefer not writing self. unless required.
# 3.2.3 Do not write internal when it is the default.
# 3.2.5 Prefer private over fileprivate where possible.
--property-types inferred
--self remove
--semicolons never
--modifier-order private,fileprivate,internal,package,public,open,private(set),fileprivate(set),internal(set),package(set),public(set),open(set),override,final,dynamic,optional,required,convenience,indirect,isolated,nonisolated,nonisolated(unsafe),lazy,weak,unowned,unowned(safe),unowned(unsafe),static,class,borrowing,consuming,mutating,nonmutating,prefix,infix,postfix,async

# Rules enabled for the LinkedIn style guide mapping.
--rules andOperator
--rules blankLineAfterSwitchCase
--rules blankLinesAtEndOfScope
--rules blankLinesAtStartOfScope
--rules blankLinesBetweenScopes
--rules braces
--rules consecutiveBlankLines
--rules consecutiveSpaces
--rules consistentSwitchCaseSpacing
--rules duplicateImports
--rules elseOnSameLine
--rules hoistPatternLet
--rules indent
--rules linebreakAtEndOfFile
--rules modifierOrder
--rules redundantClosure
--rules redundantFileprivate
--rules redundantGet
--rules redundantInit
--rules redundantInternal
--rules redundantOptionalBinding
--rules redundantParens
--rules redundantPattern
--rules redundantReturn
--rules redundantSelf
--rules redundantType
--rules redundantVoidReturnType
--rules semicolons
--rules spaceAroundBraces
--rules spaceAroundComments
--rules spaceAroundGenerics
--rules spaceAroundOperators
--rules spaceAroundParens
--rules spaceInsideBraces
--rules spaceInsideBrackets
--rules spaceInsideComments
--rules spaceInsideGenerics
--rules spaceInsideParens
--rules trailingCommas
--rules trailingSpace
--rules typeSugar
--rules unusedArguments
--rules void
--rules wrap
--rules wrapArguments
--rules wrapMultilineStatementBraces
