#!/bin/bash

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
FORMAT_SCRIPT="$REPO_ROOT/Scripts/run-swiftformat.sh"

if [ ! -f "$FORMAT_SCRIPT" ]; then
  echo "error: Missing $FORMAT_SCRIPT. Cannot run SwiftFormat pre-commit hook."
  exit 1
fi

staged_swift_files=()
while IFS= read -r -d '' path; do
  staged_swift_files+=("$path")
done < <(git diff --cached --name-only --diff-filter=ACMR -z -- '*.swift')

if [ ${#staged_swift_files[@]} -eq 0 ]; then
  exit 0
fi

partially_staged_files=()
for path in "${staged_swift_files[@]}"; do
  if ! git diff --quiet -- "$path"; then
    partially_staged_files+=("$path")
  fi
done

if [ ${#partially_staged_files[@]} -gt 0 ]; then
  echo "SwiftFormat pre-commit aborted: these staged Swift files also have unstaged changes:"
  for path in "${partially_staged_files[@]}"; do
    echo "  - $path"
  done
  echo "Stage the full file or stash the unstaged hunks, then commit again."
  exit 1
fi

SWIFTFORMAT_MODE=format SWIFTFORMAT_REQUIRED=1 /bin/sh "$FORMAT_SCRIPT" "${staged_swift_files[@]}"
git add -- "${staged_swift_files[@]}"
