{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build OpenSpace (macOS Debug)",
      "type": "process",
      "command": "xcodebuild",
      "args": [
        "-project",
        "OpenSpace.xcodeproj",
        "-scheme",
        "OpenSpace",
        "-configuration",
        "Debug",
        "-destination",
        "platform=macOS",
        "-derivedDataPath",
        "${workspaceFolder}/.vscode/DerivedData",
        "build"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "Build OpenSpace (iOS Simulator Debug)",
      "type": "process",
      "command": "xcodebuild",
      "args": [
        "-project",
        "OpenSpace.xcodeproj",
        "-scheme",
        "OpenSpace",
        "-configuration",
        "Debug",
        "-destination",
        "generic/platform=iOS Simulator",
        "-derivedDataPath",
        "${workspaceFolder}/.vscode/DerivedData-iOS",
        "build"
      ],
      "problemMatcher": [
        "$gcc"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "Run OpenSpace (iOS Simulator)",
      "type": "process",
      "command": "bash",
      "args": [
        "${workspaceFolder}/.vscode/run-ios-simulator.sh"
      ],
      "problemMatcher": [
        "$gcc"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    }
  ]
}
